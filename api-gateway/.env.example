# Application
APP_NAME=nuetra-api-gateway
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256

# Redis
REDIS_URL=redis://localhost:6379/1

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,https://nuetra.in,https://www.nuetra.in

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Upstream Services
AUTH_SERVICE_URL=http://auth-service:8001
PROFILE_SERVICE_URL=http://profile-service:8002
ASSESSMENT_SERVICE_URL=http://assessment-service:8003
SCORING_SERVICE_URL=http://scoring-engine-service:8004
NUTRITION_SERVICE_URL=http://nutrition-service:8005
CONSULTATION_SERVICE_URL=http://consultation-service:8006
PATHOLOGY_SERVICE_URL=http://pathology-service:8007
WEARABLE_SERVICE_URL=http://wearable-service:8008
ANALYTICS_SERVICE_URL=http://analytics-service:8009
ADMIN_SERVICE_URL=http://admin-service:8010
NOTIFICATION_SERVICE_URL=http://notification-service:8011
PAYMENT_SERVICE_URL=http://payment-service:8012

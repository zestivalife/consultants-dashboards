# Application
APP_NAME=nuetra-api-gateway
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256

# Redis
REDIS_URL=redis://localhost:6379/1

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# CORS (comma-separated origins)
CORS_ORIGINS=https://consultant.nuetra.in,https://consultants-dashboards.vercel.app,https://nuetra.in,https://www.nuetra.in,http://localhost:3000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Upstream Services
AUTH_SERVICE_URL=http://auth-service:8001
PROFILE_SERVICE_URL=http://profile-service:8002
ASSESSMENT_SERVICE_URL=http://assessment-service:8003
SCORING_SERVICE_URL=http://scoring-engine-service:8004
NUTRITION_SERVICE_URL=http://nutrition-service:8005

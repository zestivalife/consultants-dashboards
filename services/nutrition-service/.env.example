# Application
APP_NAME=nutrition-service
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
APP_PORT=8005

# Database
DATABASE_URL=postgresql+asyncpg://nuetra:nuetra_secret@localhost:5432/nuetra_nutrition

# Redis
REDIS_URL=redis://localhost:6379/0

# File uploads: "local" or "s3"
UPLOAD_BACKEND=local
UPLOAD_LOCAL_DIR=uploads

# S3 (only when UPLOAD_BACKEND=s3)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Application
APP_NAME=scoring-engine-service
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
APP_PORT=8004

# Database
DATABASE_URL=postgresql+asyncpg://nuetra:nuetra_secret@localhost:5432/nuetra_scoring

# Redis
REDIS_URL=redis://localhost:6379/0

# Upstream Services
PROFILE_SERVICE_URL=http://profile-service:8002
ASSESSMENT_SERVICE_URL=http://assessment-service:8003

# Cache TTL (seconds) for external service responses
CACHE_TTL_SECONDS=600

# Idempotency window (minutes) — skip recompute if scores are younger than this
SCORING_IDEMPOTENCY_MINUTES=5

# Score versioning
SCORE_VERSION=v1
ALGORITHM_VERSION=2026-03

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

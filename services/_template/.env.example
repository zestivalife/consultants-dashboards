# Application
APP_NAME=service-name
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
APP_PORT=8001

# Database
DATABASE_URL=postgresql+asyncpg://nuetra:nuetra_secret@localhost:5432/nuetra_service

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (shared secret or public key path for validation)
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

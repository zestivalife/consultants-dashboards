# Application
APP_NAME=auth-service
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
APP_PORT=8001

# Database
DATABASE_URL=postgresql+asyncpg://nuetra:nuetra_secret@localhost:5432/nuetra_auth
DB_POOL_TIMEOUT=30

# Redis
REDIS_URL=redis://localhost:6379/0
TRUSTED_HOSTS=*.railway.app,localhost,127.0.0.1

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# Account Security
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
OTP_EXPIRY_SECONDS=300

# SMTP / Email (local dev fallback)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key-here
SMTP_FROM_EMAIL=admin@nuetra.in
SMTP_FROM_NAME=Nuetra
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Email provider selection:
#   auto     = SendGrid if SENDGRID_API_KEY is set, else SMTP (default)
#   sendgrid = always use SendGrid REST API (recommended for production)
#   smtp     = always use SMTP (local dev only)
EMAIL_PROVIDER=sendgrid

# SendGrid API key
SENDGRID_API_KEY=your-sendgrid-api-key-here

# Rate Limiting
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
